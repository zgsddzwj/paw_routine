    "Get Started" : {

    },
    "Go to \"Settings → Data Export (CSV)\", select the pet(s) to export (or all pets), tap \"Start Export\" to generate a CSV file for easy sharing with your vet." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to \"Settings → Data Export (CSV)\", select the pet(s) to export (or all pets), tap \"Start Export\" to generate a CSV file for easy sharing with your vet."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "进入「设置 → 数据导出 (CSV)」，选择要导出的宠物（或全部宠物），点击「开始导出」即可生成 CSV 文件，方便发送给兽医查看。"
          }
        }
      }
    },
    "Go to Settings to enable daily reminders" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to Settings to enable daily reminders"
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "前往设置页面开启日常提醒"
          }
        }
      }
    },
    "Go to the pet details from the \"Pets\" page and tap the red \"Delete Pet Profile\" button at the bottom to delete the pet and all related records. Medical records, weight records, etc. can be deleted by swiping left or long-pressing in their respective lists." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to the pet details from the \"Pets\" page and tap the red \"Delete Pet Profile\" button at the bottom to delete the pet and all related records. Medical records, weight records, etc. can be deleted by swiping left or long-pressing in their respective lists."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在「档案」页面进入宠物详情，点击底部红色的「删除宠物档案」按钮即可删除该宠物及所有相关记录。医疗记录、体重记录等可在对应列表中左滑或长按删除。"
          }
        }
      }
    },
